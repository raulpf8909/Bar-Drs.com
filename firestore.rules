rules_version='2'

service cloud.firestore {
  match /databases/{database}/documents {
    match /products/{product} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /categories/{category} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /settings/{setting} {
      allow read, write: if request.auth != null;
    }
  }
}
